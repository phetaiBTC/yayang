# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bookstore

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# Seed admin (used by `pnpm seed:admin`)
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=admin123

# App
PORT=3000

# Registration OTP (dev: echo code in API response + log)
OTP_DEV_MODE=true
